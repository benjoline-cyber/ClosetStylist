<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- Exclude API keys — the Keystore encryption key doesn't transfer anyway,
         but keeping the encrypted blob out of cloud backup is cleaner. -->
    <exclude domain="sharedpref" path="closet_stylist_settings.xml"/>
    <!-- Exclude the database — clothing data is device-specific and can be re-added. -->
    <exclude domain="database" path="closet_stylist.db"/>
    <!-- Exclude stored images — too large for backup and tied to device-local paths. -->
    <exclude domain="file" path="closet"/>
    <exclude domain="file" path="inspiration"/>
</full-backup-content>
